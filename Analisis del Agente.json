        "format": "<div style=\"display:flex; flex-direction:row; justify-content:center; align-items:center; height:100%; background:#f4f4f4; border-radius:8px; box-sizing:border-box; padding:10px;\">\n    <div style=\"flex: 1; text-align:center;\">\n        <div style=\"font-size:14px; color:#666; font-weight:bold; text-transform:uppercase;\">Progreso del Agente</div>\n        <div style=\"font-size:42px; font-weight:bold; color:#333; line-height:1; margin-top:8px;\">{{msg.payload.paso !== undefined ? msg.payload.paso : '-'}}</div>\n    </div>\n    <div style=\"width:2px; height:80%; background:#ccc;\"></div>\n    <div style=\"flex: 1; text-align:center;\">\n        <div style=\"font-size:14px; color:#666; font-weight:bold; text-transform:uppercase;\">Energia Utilizada (W)</div>\n        <div style=\"font-size:42px; font-weight:bold; color:#2ca02c; line-height:1; margin-top:8px;\">{{msg.payload.w !== undefined ? msg.payload.w : '-'}}</div>\n    </div>\n</div>",
