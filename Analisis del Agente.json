        "id": "a0bbcdc1182b79c9",
        "type": "function",
        "z": "b4f5a7c4e0317a3c",
        "name": "Preparar Entorno V1",
        "func": "let x = [], y = [], z = [];\nconst step = 20;\nif (typeof msg.payload === 'string') {\n    let lines = msg.payload.split(/\\r?\\n/);\n    for(let i = 1; i < lines.length; i += step) {\n        let cols = lines[i].split(',');\n        if(cols.length >= 4) {\n            let v1 = parseFloat(cols[1]);\n            let v2 = parseFloat(cols[2]);\n            let w = parseFloat(cols[3]);\n            if(!isNaN(v1) && !isNaN(v2) && !isNaN(w)) { x.push(v1); y.push(v2); z.push(w); }\n        }\n    }\n}\nlet color = '#ff7f0e';\nreturn [\n    { payload: { command: \"init\", x: x, y: y, z: z, color: color } },\n    { payload: true },\n    { payload: { command: \"init_2d\" } },\n    { payload: { command: \"init_top5\" } }\n];",
