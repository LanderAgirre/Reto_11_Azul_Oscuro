        "order": 8,
        "width": "12",
        "height": "6",
        "format": "<script src=\"https://cdn.plot.ly/plotly-2.32.0.min.js\"></script>\n<div id=\"top5-v1-fin\" style=\"width:100%; height:100%; min-height:240px;\"></div>\n<script>\n(function(scope) {\n    var getLayout = function() {\n        return {\n            title: 'Los 5 Diseños mas Eficientes',\n            margin: {l:70, r:30, b:40, t:40},\n            xaxis: {\n                title: 'Consumo entre 20W y 23W',\n                range: [20, 23],\n                autorange: false\n            },\n            yaxis: {\n                type: 'category',\n                autorange: 'reversed'\n            },\n            plot_bgcolor: '#f9f9f9'\n        };\n    };\n    scope.$watch('msg', function(msg) {\n        if(!msg || !msg.payload) return;\n        if(msg.payload.command === 'init_top5') {\n            var tryInitTop = function() {\n                if(typeof Plotly === 'undefined') { setTimeout(tryInitTop, 200); return; }\n                Plotly.newPlot('top5-v1-fin', [], getLayout(), {responsive:true});\n            };\n            tryInitTop();\n        }\n        else if(msg.payload.command === 'update_top5') {\n            if(typeof Plotly === 'undefined') return;\n            var data = msg.payload.data;\n            var x_vals = data.map(function(d) { return d.w; });\n            var y_vals = data.map(function(d) { return 'Paso ' + d.paso; });\n            var trace = {\n                x: x_vals,\n                y: y_vals,\n                type: 'bar',\n                orientation: 'h',\n                marker: { color: '#ff7f0e' },\n                text: x_vals.map(function(v) { return v.toFixed(3) + ' W'; }),\n                hoverinfo: 'text',\n                textposition: 'inside',\n                insidetextanchor: 'end',\n                textfont: {color: 'white', size: 14}\n            };\n            Plotly.react('top5-v1-fin', [trace], getLayout());\n        }\n    });\n})(scope);\n</script>",
