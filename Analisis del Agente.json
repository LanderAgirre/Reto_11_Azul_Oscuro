        "width": "12",
        "height": "5",
        "format": "<script src=\"https://cdn.plot.ly/plotly-2.32.0.min.js\"></script>\n<div id=\"line-v1-fin\" style=\"width:100%; height:100%; min-height:200px;\"></div>\n<script>\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if(!msg || !msg.payload) return;\n        if(msg.payload.command === 'init_2d') {\n            var tryInitLine = function() {\n                if(typeof Plotly === 'undefined') { setTimeout(tryInitLine, 200); return; }\n                var trace = { x: [], y: [], mode: 'lines', line: {color: '#ff7f0e', width: 2} };\n                var layout = { margin: {l:50, r:20, b:40, t:20}, xaxis: {title: 'Tiempo de Simulacion'}, yaxis: {title: 'Consumo (W)'} };\n                Plotly.newPlot('line-v1-fin', [trace], layout, {responsive:true});\n            };\n            tryInitLine();\n        }\n        else if(msg.payload.command === 'add_point_2d') {\n            if(typeof Plotly !== 'undefined') {\n                Plotly.extendTraces('line-v1-fin', { x: [[msg.payload.x]], y: [[msg.payload.y]] }, [0]);\n            }\n        }\n    });\n})(scope);\n</script>",
