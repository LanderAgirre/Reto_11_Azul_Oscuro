        "name": "Ejecutar Simulacion V2",
        "func": "let ctx = flow.get(\"sim_fin_v2\") || {};\nif (ctx.interval) clearInterval(ctx.interval);\nlet raw = msg.payload;\nif (!raw || raw.includes(\"No such file\")) return null;\nlet sep = raw.includes(';') ? ';' : ',';\nlet lines = raw.split(/\\r?\\n/);\nlet ruta = [];\nfor(let i = 1; i < lines.length; i++) {\n    if(lines[i].trim() === \"\") continue;\n    let c = lines[i].split(sep);\n    let offset = c.length >= 4 ? 1 : 0;\n    if(c.length >= 3) {\n        let v1 = parseFloat(c[offset].replace(/['\"]+/g, '').trim());\n        let v2 = parseFloat(c[offset+1].replace(/['\"]+/g, '').trim());\n        let w = parseFloat(c[offset+2].replace(/['\"]+/g, '').trim());\n        if(!isNaN(v1) && !isNaN(v2) && !isNaN(w)) ruta.push({ v1: v1, v2: v2, w: w, paso: i });\n    }\n}\nif (ruta.length === 0) return null;\nctx.top5 = [];\nlet i = 0;\nctx.interval = setInterval(() => {\n    if (i >= ruta.length) {\n        clearInterval(ctx.interval);\n        return;\n    }\n    let pt = ruta[i];\n    ctx.top5.push(pt);\n    ctx.top5.sort((a,b) => a.w - b.w);\n    if (ctx.top5.length > 5) ctx.top5.pop();\n    node.send([\n        { payload: { command: \"add_point\", pt: pt } },\n        { payload: pt.v1 },\n        { payload: pt.v2 },\n        { payload: { paso: i, w: pt.w.toFixed(4) } },\n        { payload: { command: \"add_point_2d\", x: i, y: pt.w } },\n        { payload: { command: \"update_top5\", data: ctx.top5 } }\n    ]);\n    i++;\n}, 100);\nflow.set(\"sim_fin_v2\", ctx);\nnode.on(\"close\", () => { if(ctx.interval) clearInterval(ctx.interval); });\nreturn null;",
