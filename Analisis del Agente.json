    {
        "id": "c801f30ee40db42a",
        "type": "ui_template",
        "z": "b4f5a7c4e0317a3c",
        "group": "grupo_v1_final",
        "name": "Grafico Espacial V1",
        "order": 3,
        "width": "12",
        "height": "10",
        "format": "<script src=\"https://cdn.plot.ly/plotly-2.32.0.min.js\"></script>\n<div id=\"plot-v1-fin\" style=\"width:100%; height:100%; min-height:400px;\"></div>\n<script>\n(function(scope) {\n    scope.view2d = false;\n    scope.mesh = {x:[], y:[], z:[]};\n    scope.route = {x:[], y:[], z:[]};\n    scope.color = '#ff7f0e';\n    scope.renderPlot = function() {\n        if(typeof Plotly === 'undefined') { setTimeout(scope.renderPlot, 200); return; }\n        var traces = [];\n        var layout = { margin: {l:20, r:20, b:20, t:40}, title: scope.view2d ? 'Vista Plana del Recorrido' : 'Espacio de Busqueda en 3D' };\n        if(scope.view2d) {\n            traces.push({ x: scope.mesh.x, y: scope.mesh.y, mode: 'markers', marker: {color: scope.mesh.z, colorscale: 'Viridis', size: 4, opacity: 0.4}, type: 'scattergl', name: 'Area de Trabajo' });\n            traces.push({ x: scope.route.x, y: scope.route.y, mode: 'lines+markers', line: {color: scope.color, width: 3}, marker: {color: scope.color, size: 6}, type: 'scattergl', name: 'Camino del Agente' });\n            layout.xaxis = {title: 'Primera Variable'}; layout.yaxis = {title: 'Segunda Variable'}; layout.plot_bgcolor = '#f4f4f4';\n        } else {\n            traces.push({ x: scope.mesh.x, y: scope.mesh.y, z: scope.mesh.z, mode: 'markers', marker: {color: scope.mesh.z, colorscale: 'Viridis', size: 2.5, opacity: 0.15}, type: 'scatter3d', name: 'Area de Trabajo' });\n            traces.push({ x: scope.route.x, y: scope.route.y, z: scope.route.z, mode: 'lines+markers', line: {color: scope.color, width: 6}, marker: {color: scope.color, size: 5}, type: 'scatter3d', name: 'Camino del Agente' });\n            layout.scene = { xaxis: {title: 'Variable 1'}, yaxis: {title: 'Variable 2'}, zaxis: {title: 'Energia (W)'} };\n        }\n        Plotly.react('plot-v1-fin', traces, layout, {responsive: true});\n    };\n    scope.$watch('msg', function(msg) {\n        if(!msg || !msg.payload) return;\n        if(msg.payload.command === 'init') {\n            scope.mesh = {x: msg.payload.x, y: msg.payload.y, z: msg.payload.z};\n            scope.route = {x:[], y:[], z:[]};\n            scope.color = msg.payload.color;\n            scope.renderPlot();\n        } else if(msg.payload.command === 'add_point') {\n            if(typeof Plotly === 'undefined') return;\n            var pt = msg.payload.pt;\n            scope.route.x.push(pt.v1); scope.route.y.push(pt.v2); scope.route.z.push(pt.w);\n            if(scope.view2d) {\n                Plotly.extendTraces('plot-v1-fin', { x: [[pt.v1]], y: [[pt.v2]] }, [1]);\n            } else {\n                Plotly.extendTraces('plot-v1-fin', { x: [[pt.v1]], y: [[pt.v2]], z: [[pt.w]] }, [1]);\n            }\n        } else if(msg.payload.command === 'toggle_view') {\n            scope.view2d = !scope.view2d;\n            scope.renderPlot();\n        }\n    });\n})(scope);\n</script>",
